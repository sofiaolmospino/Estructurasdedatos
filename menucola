int main()
{
    Cola q;
    int opcion = -1;
    char d;
    do {
        cout << "----- MENU -----" << endl;
        cout << "1. Llenar cola"<<endl;
        cout << "2. Vaciar cola" << endl;
        cout << "3. Mostrar cola"<<endl;
        cout << "4. Mostrar tamano de cola" << endl;
        cout << "0. Salir" << endl;

        cin >> opcion;

        switch (opcion) {
        case 1:
            cout << "Ingrese el elemento: " << endl;
            cin >> d;
            q.put(d);
            break;
        case 2:
            q.get();
            break;
        case 3:
            q.verCola();
            break;
        case 4:
            cout<<q.size()<<endl;
            break;
