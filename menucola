            cout << "Saliendo..." << endl;
            break;
        default:
            cout << "Ingresar opcion valida"<<endl;
        }
    } while (opcion != 0);

    cout << "\nPara terminar oprima <Enter> ...";
    cin.get();
    return 0;
}
