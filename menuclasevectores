//8
void Vector::mayorDiferencia(){

    float mayor=0;

    for(int i=0;i<n-1;i++){

        float dif=abs(vec[i+1]-vec[i]);

        if(dif>mayor)
            mayor=dif;
    }

    cout<<"Mayor diferencia: "<<mayor<<endl;
}

//9
void Vector::concatenar(){

    int m;

    cout<<"Tamaño segundo vector: ";
    cin>>m;

    for(int i=0;i<m;i++)
        cin>>vec2[i];

    for(int i=0;i<m;i++)
        vec[n+i]=vec2[i];

    n=n+m;
}

//10
void Vector::intercalar(){

    int m;
    int b[MAX],c[MAX];

    cout<<"Tamaño segundo vector: ";
    cin>>m;

    for(int i=0;i<m;i++)
        cin>>b[i];

    int i=0,j=0,k=0;

    while(i<n && j<m){

        if(vec[i]<=b[j])
            c[k++]=vec[i++];
        else
            c[k++]=b[j++];
    }

    while(i<n)
        c[k++]=vec[i++];

    while(j<m)
        c[k++]=b[j++];

    cout<<"Resultado: ";
    for(int t=0;t<k;t++)
        cout<<c[t]<<" ";
}

//11
void Vector::contarValores(){

    int pos=0,neg=0,cero=0;

    for(int i=0;i<n;i++){

        if(vec[i]>0)
            pos++;

        else if(vec[i]<0)
            neg++;

        else
            cero++;
    }

    cout<<"Positivos "<<pos<<endl;
    cout<<"Negativos "<<neg<<endl;
    cout<<"Ceros "<<cero<<endl;
}

//12
void Vector::eliminarDuplicados(){

    for(int i=0;i<n;i++){

        for(int j=i+1;j<n;j++){

            if(vec[i]==vec[j]){

                for(int k=j;k<n-1;k++)
                    vec[k]=vec[k+1];

                n--;
                j--;
            }
        }
    }
}

//14
void Vector::ordenarVector(){

    for(int i=0;i<n-1;i++){

        for(int j=i+1;j<n;j++){

            if(vec[i]>vec[j]){

                int aux=vec[i];
                vec[i]=vec[j];
                vec[j]=aux;
            }
        }
    }
}

//17
void Vector::fibonacci(){

    cout<<"Cantidad: ";
    cin>>n;

    vec[0]=0;
    vec[1]=1;

    for(int i=2;i<n;i++)
        vec[i]=vec[i-1]+vec[i-2];

    mostrarVector();
}

