#include <iostream>
#include <string>
using namespace std;

#define MAX 100

class Vector{

private:
    int vec[MAX];
    int vec2[MAX];
    int n;

public:
    Vector();

    void cargarVector();
    void mostrarVector();

    int maximoVector();              // 1
    int minimoVector();              // 2
    double promedio();               // 3

    void revertirVector();           // 13
    void revertirEnOtro();           // 4
    bool esCapicua();                // 5

    void promedio3();                // 6
    void numeroLiteral(int n);       // 7
    void mayorDiferencia();          // 8

    void concatenar();               // 9
    void intercalar();               // 10

    void contarValores();            // 11
    void eliminarDuplicados();       // 12

    void ordenarVector();            // 14

    void top3();                     // 15
    void menuAlumnos();              // 16

    void fibonacci();                // 17
};

#include "vector.h"

Vector::Vector(){
    n=0;
}

void Vector::cargarVector(){

    cout<<"Tamaño: ";
    cin>>n;

    for(int i=0;i<n;i++){
        cin>>vec[i];
    }
}

void Vector::mostrarVector(){

    for(int i=0;i<n;i++){
        cout<<vec[i]<<" ";
    }
    cout<<endl;
}

//1
int Vector::maximoVector(){

    int max=vec[0];

    for(int i=1;i<n;i++){
        if(vec[i]>max)
            max=vec[i];
    }

    return max;
}

//2
int Vector::minimoVector(){

    int min=vec[0];

    for(int i=1;i<n;i++){
        if(vec[i]<min)
            min=vec[i];
    }

    return min;
}

//3
double Vector::promedio(){

    int suma=0;

    for(int i=0;i<n;i++){
        suma+=vec[i];
    }

    return (double)suma/n;
}

//4
void Vector::revertirEnOtro(){

    for(int i=0;i<n;i++){
        vec2[i]=vec[n-1-i];
    }

    cout<<"Vector invertido: ";
    for(int i=0;i<n;i++){
        cout<<vec2[i]<<" ";
    }
    cout<<endl;
}

//13
void Vector::revertirVector(){

    for(int i=0;i<n/2;i++){

        int aux=vec[i];
        vec[i]=vec[n-1-i];
        vec[n-1-i]=aux;
    }
}

//5
bool Vector::esCapicua(){

    for(int i=0;i<n/2;i++){

        if(vec[i]!=vec[n-1-i])
            return false;
    }

    return true;
}

//6
void Vector::promedio3(){

    double p;

    for(int i=0;i<n-2;i++){

        p=(vec[i]+vec[i+1]+vec[i+2])/3.0;

        cout<<"P"<<i+1<<" = "<<p<<endl;
    }
}

