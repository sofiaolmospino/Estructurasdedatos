}


int longitud(string nombre) {
	int longitud = nombre.length();
	return longitud;
}

bool compararCadenas(string var1, string var2) {
	cout << endl << "Ejemplo de uso de compare para determinar si dos cadenas son iguales";
	if (var1.compare(var2) == 0)
	return true;
	else
		cout << var1 << " es diferente que " << var2 << "." << endl;
	return false;
}

int numVocales(string nombre) {
	int cont = 0;
	cout << endl << "Ejemplo de uso de elementos individuales con at: " << endl;
	cont = 0;
	for (int i = 0; i < longitud; i++)
		if (nombre.at(i) == 'a' || nombre.at(i) == 'e' || nombre.at(i) == 'i' || nombre.at(i) == 'o' || nombre.at(i) == 'u')
			cont++;
	cout << "Numero de vocales: " << cont << endl;
}

void extraerDeString(string nombre, int pos, int cont) {
	cout << endl << "Ingrese desde donde desea extraer el substring: ";
	cin >> pos;
	cout << nombre.substr(pos, longitud - pos);
	cin.ignore();
}

void intercambiar(string nombre, string var2) {
	cout << endl << "Intercambia variables";
	nombre.swap(var2);
	cout << nombre;
	cout << var2;
}

int encontrarChar(string nombre, string var2) {
	cout << var2.find(' ');
	int longitud = var2.length();
	for (int i = 0; i < longitud; i++)
		if (var2.at(i) == ' ')
			cout << endl << "Existe un espacio en: " << i;
}

string invertir(string nombre) {
	string var2 = nombre;
	char aux;
	int longitud = nombre.length();
	for (int i = 0; i < longitud / 2; i++)
	{
		aux = nombre[i];
		nombre[i] = nombre[longitud - 1 - i];
		nombre[longitud - 1 - i] = aux;
	}
}

bool palindromo(string nombre) {
	string var2 = nombre;
	char aux;
	int longitud = nombre.length();
	for (int i = 0; i < longitud / 2; i++)
	{
		aux = nombre[i];
		nombre[i] = nombre[longitud - 1 - i];
		nombre[longitud - 1 - i] = aux;
	}
	if (var2.compare(nombre) == 0)
		return true;
}

void quitarVocal(string nombre, string var2) {
	var2 = nombre;
	int cont = 0;
	int longitud = nombre.length();
	for (int i = 0; i < longitud; i++)
		if (nombre[i] != 'a' && nombre[i] != 'e' && nombre[i] != 'i' && nombre[i] != 'o' && nombre[i] != 'u')
		{
			var2[cont] = nombre[i];
			cont++;
		}
	cout << "Sin vocales es: " << var2;
}
	
