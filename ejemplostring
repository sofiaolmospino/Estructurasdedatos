#include <iostream>
#include <string>

using namespace std;

//prototipos
int longitud(string nombre);
bool compararCadenas(string var1, string var2);
int numVocales(string nombre);
string extraerDeString(string nombre, int pos, int cont);
string intercambiar(string nombre, string var2);
int encontrarChar(string nombre, string var2);
