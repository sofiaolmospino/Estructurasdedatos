#pragma once
#define MAX 10
#include <iostream>
#include <string>
using namespace std;

class Vector
{
	private: //atributos
		string dato[MAX];
		int n;
	public: //metodos
		Vector();
		void cargar(int tam);
		void mostrar(); //para trabajar con los atributos const
		void setDato(int pos, string valor); //setter cambia datos
		string getDato(int pos) const; //getter recibe datos
		void setN(int tam);
		int getN() const;


};

#include "Vector.h"
#include <iostream>
#include <string>

Vector::Vector() {
	n = 0;
}

void Vector::cargar(int tam) {
	n = tam; //modificando el atributo de la clase que va a afectar al objeto
	for (int i = 0; i < n; i++) {
		cout << "Elemento [" << i << "]: ";
		cin >> dato[i];
	}
}

void Vector::mostrar() { //para trabajar con los atributos const
	cout << "[";
	for (int i = 0; i < n; i++) {
		cout << dato[i];
		if (i < n - 1)
			cout << " ";
	}
	cout << " ]";
}

void Vector::setDato(int pos, string valor) {//setter cambia datos
	dato[pos] = valor;
}

string Vector::getDato(int pos) const{ //getter recibe datos
	return dato[pos];
}

void Vector::setN(int tam) {
	n = tam;
}

int Vector::getN() const {
	return n;
}

// arraysarrays.cpp : Este archivo contiene la función "main". La ejecución del programa comienza y termina ahí.
//
#include <iostream>
#include "Vector.h"

using namespace std;

void cargarVectorDeVectores(Vector v[], int n);
void generarMatriz(Vector v[], Vector m[][MAX], int n);
void mostrarVectorDeVectores(Vector v[], int n);
void mostrarMatriz(Vector m[][MAX], int n);

int main()
{
    int tamanio;
    Vector vec[MAX];
    Vector matriz[MAX][MAX];
    do {
        cout << "Ingrese el tamanio: ";
        cin >> tamanio;
    } while ((tamanio <= 0) || (tamanio > MAX));

    cargarVectorDeVectores(vec, tamanio);
    mostrarVectorDeVectores(vec, tamanio);
    generarMatriz(vec, matriz, tamanio);
    mostrarMatriz(matriz, tamanio);

    return 0;

}

void cargarVectorDeVectores(Vector v[], int n) {
    for (int i = 0; i < n; i++) {
        cout << "Cargando vector [" << i << "]: ";
        v[i].cargar(n);
    }
}

void generarMatriz(Vector v[], Vector m[][MAX], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            m[i][j].setN(n);
            for (int k = 0; k < n; k++) {
                m[i][j].setDato(k, v[i].getDato(j));
            }
        }
    }
}

void mostrarVectorDeVectores(Vector v[], int n) {
    cout << "Mostrando vector de vectores" << endl;
    for (int i = 0; i < n; i++) {
        cout << "V [" << i << "]: ";
        v[i].mostrar();
    }
}

void mostrarMatriz(Vector m[][MAX], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            m[i][j].mostrar();
            cout << " ";
        }
    }
}
