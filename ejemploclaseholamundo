#include <iostream>
#include <string>

using namespace std;

class Saludo {
    private: //atributos
        string mensaje = "Hola Mundo";
    public: //métodos
        void mostrar() {
        cout << mensaje;
        }
};

int main()
{
    //Declarar un objeto de la clase Saludo se llama saludito
    Saludo saludito;
    saludito.mostrar(); //Utilizacion de un metodo de la clase
    return 0;
}
